# ================================================================
# 本番環境用 .env サンプル
# ================================================================
# 使い方:
#   本番ビルド時に docker-compose-prd.yml の build.args に渡す。
#   直接 .env にコピーする必要はない。
#   （docker-compose-prd.yml の NEXT_PUBLIC_API_URL / NEXT_PUBLIC_SERVER_HOST 参照）
# ================================================================

# バックエンドAPIのURL（本番ドメイン）
NEXT_PUBLIC_API_URL=https://elms-app.com

# Next.js Image最適化で許可するホスト名
NEXT_PUBLIC_SERVER_HOST=elms-app.com
