# ================================================================
# ローカル開発用 .env サンプル
# ================================================================
# 使い方:
#   1. このファイルを .env にコピー
#      cp .env.dev.example .env
#   2. npm run dev でフロントエンドを起動
# ================================================================

# バックエンドAPIのURL（ローカルのSpring Boot）
NEXT_PUBLIC_API_URL=http://localhost:8080

# Next.js Image最適化で許可するホスト名
NEXT_PUBLIC_SERVER_HOST=localhost
